# Database Configuration
DATABASE_URL=postgresql+psycopg2://username:password@localhost:5432/database_name

# Alpaca static keys — market data only (quotes, bars, asset lists)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Alpaca Connect OAuth — per-user trading
# Get these from your Alpaca dashboard after registering your OAuth app
ALPACA_CLIENT_ID=your_alpaca_oauth_client_id
ALPACA_CLIENT_SECRET=your_alpaca_oauth_client_secret
# Must exactly match the redirect URI registered in the Alpaca dashboard
ALPACA_REDIRECT_URI=clauapp://alpaca/callback

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_here

# Token encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here